{
  "compilerOptions": {
    "target": "ES2019",
    "module": "esnext",
    "strict": true,
    "moduleResolution": "bundler",
    "resolvePackageJsonExports": false,
    "composite": true,
    "declarationMap": true,
    "outDir": "dist/ts",
    "declarationDir": "dist",
    "allowSyntheticDefaultImports": true,
    "lib": ["esnext", "DOM"],
    "types": ["node"],
    "rootDir": "..",
    "allowJs": true,
    "declaration": true
  },
  "include": ["src/**/*", "../codecs/**/*"]
}
