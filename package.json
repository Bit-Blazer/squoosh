{
  "name": "squoosh-monorepo",
  "version": "1.3.0",
  "workspaces": [
    "squoosh-app",
    "squoosh-node",
    "squoosh-cli",
    "squoosh"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "clean": "npm run clean --workspaces --if-present && rimraf node_modules",
    "dev": "npm run dev --workspace=squoosh-app",
    "format": "prettier --write \"**/*.{js,cjs,mjs,ts,tsx,css,md,json}\"",
    "prepare": "husky",
    "test": "npm run test --workspaces --if-present"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,css,json,md,ts,tsx}": "prettier --write",
    "*.{c,h,cpp,hpp}": "clang-format -i",
    "*.rs": "rustfmt"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "rimraf": "^6.1.3"
  }
}
