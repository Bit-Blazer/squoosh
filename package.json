{
  "private": true,
  "name": "squoosh",
  "version": "1.1.4",
  "license": "apache-2.0",
  "workspaces": [
    "squoosh-app",
    "squoosh",
    "squoosh-node",
    "squoosh-cli"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm test --workspaces --if-present"
  },
  "devDependencies": {
    "husky": "^7.0.2",
    "lint-staged": "^10.5.1",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.8.3",
    "which": "^2.0.2"
  },
  "lint-staged": {
    "*.{js,css,json,md,ts,tsx}": "prettier --write",
    "*.{c,h,cpp,hpp}": "clang-format -i",
    "*.rs": "rustfmt"
  }
}
